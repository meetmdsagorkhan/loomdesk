# Database
DATABASE_URL="postgresql://user:password@localhost:5432/loomdesk"

# NextAuth
AUTH_SECRET="your-auth-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Security / Rate limiting
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_REPLY_TO=support@yourdomain.com

# Google Calendar (for holidays)
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key

# Rate Limiting & Security
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOCKOUT_BASE_MS=900000
SESSION_MAX_AGE_MS="43200000"
SESSION_REMEMBER_ME_MAX_AGE_MS="2592000000"
EMAIL_VERIFICATION_TOKEN_TTL_MS="86400000"
MESSAGE_RATE_LIMIT_MAX_REQUESTS="10"
MESSAGE_RATE_LIMIT_WINDOW_MS="60000"
PASSWORD_RESET_TOKEN_TTL_MS="3600000"

# Supabase (for real-time notifications)
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
