// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerifiedAt DateTime?
  name          String
  password      String
  role          Role      @default(MEMBER)
  isActive      Boolean   @default(true)
  sessionVersion Int      @default(0)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  twoFactorRecoveryCodes Json?
  twoFactorConfirmedAt DateTime?
  image         String?
  position      String?
  department    String?
  company       String?
  joiningDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reports       Report[]
  scoreEvents   ScoreEvent[]
  leaveRequests LeaveRequest[]
  shifts        ShiftAssignment[]
  shiftExceptions ShiftException[]
  notifications  Notification[]
  sentMessages  Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")
  invitedBy     String?
  invitations   Invitation[] @relation("invitedBy")
  emailVerificationTokens EmailVerificationToken[]
  submissions  UserSubmission[]
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  status      AuditStatus
  actorId     String?
  actorEmail  String?
  actorRole   String?
  targetType  String?
  targetId    String?
  targetEmail String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([targetId, createdAt])
}

model RateLimitBucket {
  key         String   @id
  count       Int
  windowStart DateTime
  blockedUntil DateTime?
  updatedAt   DateTime @updatedAt
}

model AccountLockoutState {
  subject     String   @id
  failureCount Int
  firstFailedAt DateTime
  lockedUntil DateTime?
  updatedAt   DateTime @updatedAt
}

model Invitation {
  id          String           @id @default(cuid())
  email       String           @unique
  token       String           @unique @default(cuid())
  role        Role             @default(MEMBER)
  status      InvitationStatus @default(PENDING)
  invitedById String
  invitedBy   User             @relation("invitedBy", fields: [invitedById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
}

model Report {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  date        DateTime      @db.Date
  status      ReportStatus  @default(DRAFT)
  submittedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  entries     ReportEntry[]
  @@unique([userId, date])
}

model ReportEntry {
  id             String      @id @default(cuid())
  reportId       String
  report         Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  type           EntryType
  referenceId    String
  status         EntryStatus
  note           String
  pendingReason  String?
  createdAt      DateTime    @default(now())
  feedback       Feedback[]
  @@unique([reportId, referenceId])
}

model ScoreEvent {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  reportId    String?
  entryId     String?
  severity    ScoreSeverity
  deduction   Float
  reason      String
  adminNote   String?
  createdById String
  createdAt   DateTime        @default(now())
}

model Feedback {
  id        String      @id @default(cuid())
  entryId   String
  entry     ReportEntry @relation(fields: [entryId], references: [id])
  comment   String
  authorId  String
  createdAt DateTime    @default(now())
}

model UserSubmission {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  type        SubmissionType
  title       String
  description String
  status      SubmissionStatus @default(OPEN)
  priority    SubmissionPriority @default(MEDIUM)
  adminNote   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([type, status])
  @@index([userId, createdAt])
}

model LeaveRequest {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  startDate   DateTime      @db.Date
  endDate     DateTime      @db.Date
  reason      String
  status      LeaveStatus   @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime      @default(now())
}

model Shift {
  id              String            @id @default(cuid())
  name            String
  startTime       String
  endTime         String
  reportDeadline  String
  createdAt       DateTime          @default(now())
  assignments     ShiftAssignment[]
  exceptions      ShiftException[]
}

model ShiftAssignment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id])
  startDate DateTime @db.Date
  endDate   DateTime? @db.Date
  createdAt DateTime @default(now())
}

model ShiftException {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @db.Date
  shiftId   String?
  shift     Shift?   @relation(fields: [shiftId], references: [id])
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  sender     User      @relation("MessageSender", fields: [senderId], references: [id])
  receiverId String?   // Null means it's a channel message
  receiver   User?     @relation("MessageReceiver", fields: [receiverId], references: [id])
  channel    String?   // 'general', 'announcements', etc.
  content    String
  read       Boolean   @default(false)
  readAt     DateTime? // Tracks exactly when it was read for read receipts
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, read, createdAt])
}

enum Role {
  ADMIN
  TEAM_LEAD
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}

enum EntryType {
  TICKET
  CHAT
}

enum EntryStatus {
  SOLVED
  PENDING
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScoreSeverity {
  MINOR
  MAJOR
}

enum AuditStatus {
  SUCCESS
  FAILURE
}

enum SubmissionType {
  FEEDBACK
  BUG_REPORT
  FEATURE_REQUEST
}

enum SubmissionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SubmissionPriority {
  LOW
  MEDIUM
  HIGH
}
